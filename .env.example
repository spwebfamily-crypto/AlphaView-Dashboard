PROJECT_NAME=AlphaView Dashboard
APP_VERSION=0.1.0
APP_ENV=development
EXECUTION_MODE=PAPER
ENABLE_LIVE_TRADING=false
POSTGRES_DB=alphaview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/alphaview
BACKEND_CORS_ORIGINS=http://localhost:5173,http://frontend:5173
FRONTEND_API_BASE_URL=/api/v1
FRONTEND_BASE_URL=http://localhost:5173
ALLOW_PUBLIC_REGISTRATION=true
AUTH_SECRET_KEY=change-me-in-production
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_COOKIE_SECURE=false
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.massive.com
POLYGON_WEBSOCKET_URL=wss://socket.massive.com/stocks
FINNHUB_API_KEY=
FINNHUB_SECRET_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
IBKR_HOST=
IBKR_PORT=7497
IBKR_CLIENT_ID=101
BROKER_ADAPTER=mock
DEFAULT_SYMBOLS=AAPL,MSFT,NVDA
DEFAULT_TIMEFRAME=1min
ARTIFACT_ROOT=../reports
MODEL_REGISTRY_DIR=../reports/model_runs
BACKTEST_REPORT_DIR=../reports/backtests
DEMO_SEED_PATH=../examples/sample_demo_seed.json
REQUEST_TIMEOUT_SECONDS=30
WITHDRAWALS_ENABLED=false
WITHDRAWALS_CURRENCY=usd
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_CONNECT_API_VERSION=2026-01-28.clover
STRIPE_ACCOUNT_LINKS_API_VERSION=2025-08-27.preview
STRIPE_CONNECT_RETURN_URL=
STRIPE_CONNECT_REFRESH_URL=
