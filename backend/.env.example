PROJECT_NAME=AlphaView Dashboard
APP_VERSION=0.1.0
APP_ENV=development
EXECUTION_MODE=PAPER
ENABLE_LIVE_TRADING=false
POSTGRES_DB=alphaview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5433
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/alphaview
BACKEND_CORS_ORIGINS=http://localhost:5173,http://frontend:5173
FRONTEND_API_BASE_URL=/api/v1
FRONTEND_BASE_URL=http://localhost:5173
ALLOW_PUBLIC_REGISTRATION=true
AUTH_SECRET_KEY=change-me
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_VERIFICATION_CODE_TTL_MINUTES=10
AUTH_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=AlphaView Dashboard
EMAIL_SMTP_USE_STARTTLS=true
EMAIL_SMTP_USE_SSL=false
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.massive.com
POLYGON_WEBSOCKET_URL=wss://socket.massive.com/stocks
FINNHUB_API_KEY=
FINNHUB_SECRET_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1
EODHD_API_TOKEN=
EODHD_BASE_URL=https://eodhd.com/api
IBKR_HOST=host.docker.internal
IBKR_PORT=7497
IBKR_CLIENT_ID=101
BROKER_ADAPTER=mock
DEFAULT_SYMBOLS=SAP.DE,MC.PA,AIR.PA
DEFAULT_TIMEFRAME=1min
MARKET_REGION_LABEL=Europe
MARKET_STATUS_EXCHANGE=EU
ARTIFACT_ROOT=../reports
MODEL_REGISTRY_DIR=../reports/model_runs
BACKTEST_REPORT_DIR=../reports/backtests
DEMO_SEED_PATH=../examples/sample_demo_seed.json
REQUEST_TIMEOUT_SECONDS=30
BACKEND_PORT=18000
WITHDRAWALS_ENABLED=false
WITHDRAWALS_CURRENCY=eur
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_API_BASE=https://api.stripe.com
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_CONNECT_MODE=auto
STRIPE_CONNECT_API_VERSION=2026-01-28.clover
STRIPE_ACCOUNT_LINKS_API_VERSION=2025-08-27.preview
STRIPE_CONNECT_RETURN_URL=http://localhost:5173/?stripe=return
STRIPE_CONNECT_REFRESH_URL=http://localhost:5173/?stripe=refresh
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/?billing=success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/?billing=cancel
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:5173/?billing=portal
